# Supabase configuration (copy this file to .env.local and fill in the values)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# API Keys for AI Providers (Server-side only)
GROQ_API_KEY=
OPENROUTER_API_KEY=
NVIDIA_API_KEY=

# Direct Provider Keys (Optional: fallbacks to OpenRouter if not configured)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
PERPLEXITY_API_KEY=
DEEPSEEK_API_KEY=
MISTRAL_API_KEY=
MISTRAL_API=
CEREBRAS_API_KEY=

# Stripe Configuration (Server-side only)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_MONTHLY=
STRIPE_PRICE_ID_YEARLY=

# Supabase Service Role Key (Server-side only - NEVER expose to browser)
SUPABASE_SERVICE_ROLE_KEY=
